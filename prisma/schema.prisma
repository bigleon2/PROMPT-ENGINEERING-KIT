generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectType String   @default("web")
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sessions    Session[]
}

model Session {
  id              String   @id @default(cuid())
  title           String
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentStep     Int      @default(1)
  status          String   @default("in_progress")
  context         String   @default("")
  sourceMaterial  String   @default("")
  results         String   @default("")
  constraints     String   @default("")
  iterations      String   @default("")
  environment     String   @default("")
  inputUrl        String?
  inputFormat     String   @default("markdown")
  selectedBlocks  String   @default("A,C,E,G,H")
  complexity      String   @default("moyen")
  language        String   @default("fr")
  executionMode   String   @default("cot")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  steps           Step[]
  validations     Validation[]
}

model Step {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stepNumber  Int
  name        String
  status      String   @default("pending")
  output      String   @default("")
  duration    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Validation {
  id            String   @id @default(cuid())
  sessionId     String
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  completeness  Int      @default(0)
  coherence     Int      @default(0)
  quality       Int      @default(0)
  totalScore    Int      @default(0)
  maxScore      Int      @default(25)
  checks        String   @default("[]")
  passed        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  systemPrompt String
  blocks      String   @default("A,C,E,G,H")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}